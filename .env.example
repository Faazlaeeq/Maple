# ──────────────────────────────────────────
# Maple — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────

# Google Gemini (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Firebase / Firestore
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email Notifications (from https://resend.com)
RESEND_API_KEY=
NOTIFICATION_EMAIL=owner@example.com

# Admin Dashboard
ADMIN_TOKEN=change-me-to-a-strong-random-string

# Client Config
CLIENT_ID=maplewood-dental

# Widget URL (set after deploying widget)
WIDGET_API_URL=http://localhost:3001

# --- Phase 2: Twilio OTP & Google Calendar ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

GOOGLE_CALENDAR_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
